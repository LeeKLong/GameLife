  .gold-bg { background-color: rgba(255, 214, 10, 0.2); }

  .title-row-box { 
    margin-top: 10px; margin-bottom: 20px; padding-left: 4px;
    flex-direction: row; align-items: center;
  }
  .page-main-title { font-size: 30px; font-weight: bold; }
  .divider { margin: 0 16px; font-size: 28px; font-weight: normal; }
  
  .scroll-view { flex: 1; flex-direction: column; padding: 16px; }
  .spacer { height: 80px; }

  .balance-card { 
    background-color: #1C1C1E; padding: 20px; border-radius: 26px; 
    flex-direction: row; justify-content: space-between; align-items: center; 
    margin-bottom: 24px; border: 2px solid rgba(255, 255, 255, 0.05);
  }
  .balance-label { color: #8E8E93; font-size: 24px; }
  .balance-row { flex-direction: row; align-items: center; }
  .coin-icon-circle { width: 32px; height: 32px; border-radius: 16px; justify-content: center; align-items: center; margin-right: 8px; }
  .coin-icon-txt { font-size: 20px; font-weight: bold; }
  .balance-val { font-size: 32px; font-weight: bold; }

  .section-header { flex-direction: row; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .section-title { font-size: 28px; color: #fff; font-weight: bold; }
  .header-right { flex-direction: row; align-items: center; }
  
  .capsule-btn {
    padding: 6px 16px; border-radius: 20px;
    background-color: #1C1C1E; border: 1px solid #2C2C2E;
    margin-left: 8px; align-items: center; justify-content: center;
  }
  .capsule-txt { font-size: 20px; font-weight: bold; }

  .title-filter-box { flex-direction: row; align-items: center; }
  .filter-arrow { font-size: 24px; margin-left: 6px; font-weight: bold; }

  /* Picker Styles */
  .picker-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background-color: rgba(0,0,0,0.6);
    justify-content: center; align-items: flex-end;
    z-index: 120;
  }
  .picker-content {
    width: 100%; height: 70%;
    background-color: #1C1C1E;
    border-top-left-radius: 26px; border-top-right-radius: 26px;
    padding: 24px; flex-direction: column;
    align-items: center;
    border-top: 1px solid #2C2C2E;
  }
  .cat-popup-height { height: 50%; }
  .popup-handle { width: 60px; height: 6px; background-color: #3A3A3C; border-radius: 3px; margin-bottom: 20px; opacity: 0.5; }
  
  .picker-header { width: 100%; flex-direction: row; justify-content: center; align-items: center; margin-bottom: 20px; }
  .picker-title { font-size: 28px; color: #fff; font-weight: bold; }
  
  .picker-scroll { flex: 1; width: 100%; flex-direction: column; }
  
  .picker-item-box {
    width: 100%; 
    padding: 16px 20px; 
    border-radius: 26px;
    background-color: #2C2C2E; 
    margin-bottom: 12px;
    flex-direction: row; 
    justify-content: space-between; 
    align-items: center;
    border: 2px solid rgba(255, 255, 255, 0.05);
  }
  .picker-item-left { flex-direction: column; flex: 1; margin-right: 12px; }
  .picker-cat-name { font-size: 26px; color: #fff; font-weight: bold; }

  .popup-active-orange { background-color: rgba(255, 159, 10, 0.15); border-color: rgba(255, 159, 10, 0.3); }
  .popup-active-blue { background-color: rgba(78, 129, 238, 0.15); border-color: rgba(78, 129, 238, 0.3); }
  .popup-active-green { background-color: rgba(163, 250, 0, 0.15); border-color: rgba(163, 250, 0, 0.3); }
  .popup-active-purple { background-color: rgba(191, 90, 242, 0.15); border-color: rgba(191, 90, 242, 0.3); }
  .check-icon { font-size: 26px; font-weight: bold; }
  .c-white { color: #fff; }

  .shop-list, .inv-list { flex-direction: column; }
  .shop-item, .inv-item { 
    flex-direction: row; background-color: #1C1C1E; border-radius: 26px; 
    padding: 16px; margin-bottom: 12px; align-items: center; border: 2px solid rgba(255, 255, 255, 0.05); 
  }
  .item-main { flex: 1; flex-direction: column; }
  .name-row { flex-direction: row; align-items: center; margin-bottom: 6px; width: 100%; }
  
  .item-type { font-size: 16px; margin-right: 6px; font-weight: bold; padding: 2px 6px; border-radius: 6px; flex-shrink: 0; }
  .type-box { color: #BF5AF2; background-color: rgba(191, 90, 242, 0.15); }
  .type-prop { color: #4E81EE; background-color: rgba(78, 129, 238, 0.15); }
  
  .item-name { font-size: 26px; color: #fff; font-weight: bold; flex: 1; lines: 1; text-overflow: ellipsis; }
  .item-desc { font-size: 20px; color: #8E8E93; lines: 1; text-overflow: ellipsis; width: 100%; }
  
  .buy-wrapper { flex-shrink: 0; padding-left: 10px; justify-content: flex-end; align-items: center; }
  .use-wrapper { flex-shrink: 0; padding-left: 10px; justify-content: flex-end; align-items: center; }
  .craft-btn-box { flex-shrink: 0; padding: 8px 16px; border-radius: 16px; background-color: #2C2C2E; }
  .craft-btn-txt { font-size: 22px; font-weight: bold; }
  .buy-btn { padding: 8px 16px; border-radius: 16px; }
  .use-btn { background-color: #2C2C2E; padding: 8px 16px; border-radius: 16px; }
  .btn-txt { font-size: 22px; font-weight: bold; }
  .use-txt { font-size: 22px; color: #fff; font-weight: bold; }
  
  .sort-zone { flex-direction: column; align-items: center; justify-content: center; width: 28px; margin-right: 4px; }
  .sort-btn { font-size: 22px; font-weight: bold; padding: 4px 0; text-align: center; }

  .del-btn { width: 44px; height: 44px; justify-content: center; align-items: center; }
  .del-txt { font-size: 32px; color: #FF453A; font-weight: bold; }

  .recipe-list { flex-direction: column; }
  .recipe-item {
    flex-direction: row; background-color: #1C1C1E; border-radius: 26px; 
    padding: 16px; margin-bottom: 12px; align-items: center; border: 2px solid rgba(255, 255, 255, 0.05);
  }
  .recipe-main { flex: 1; flex-direction: column; }
  .recipe-header { flex-direction: row; align-items: center; margin-bottom: 6px; }
  .recipe-name { font-size: 26px; color: #fff; font-weight: bold; margin-right: 10px; }
  .recipe-type-tag { font-size: 16px; padding: 2px 8px; border-radius: 6px; font-weight: bold; }
  .recipe-target { font-size: 20px; color: #8E8E93; margin-bottom: 8px; }
  .materials-row { flex-direction: row; flex-wrap: wrap; }
  .material-tag { font-size: 14px; color: #8E8E93; background-color: #2C2C2E; padding: 2px 6px; border-radius: 4px; margin-right: 6px; margin-bottom: 4px; }
  
  .empty-box { margin-top: 60px; align-items: center; }
  .empty-txt { color: #48484A; font-size: 24px; }

</style>
