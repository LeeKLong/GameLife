  }

  .editing-text { text-overflow: clip; }

  .pill-gray { background-color: #2C2C2E; }
  .pill-orange { background-color: rgba(255, 159, 10, 0.15); }
  .pill-blue { background-color: rgba(78, 129, 238, 0.15); }
  .pill-green { background-color: rgba(163, 250, 0, 0.15); }
  .pill-purple { background-color: rgba(191, 90, 242, 0.15); }
  .pill-red { background-color: rgba(255, 69, 58, 0.15); }
  .pill-gold { background-color: rgba(255, 214, 10, 0.15); }

  /* Theme Colors */
  .c-orange { color: #FF9F0A; }
  .c-blue { color: #4E81EE; }
  .c-green { color: #A3FA00; }
  .c-purple { color: #BF5AF2; }
  .c-red { color: #FF453A; }
  .c-gold { color: #FFD60A; }
  .c-gray { color: #8E8E93; }

  .bg-orange { background-color: #FF9F0A; }
  .bg-blue { background-color: #4E81EE; }
  .bg-green { background-color: #A3FA00; }
  .bg-purple { background-color: #BF5AF2; }
  
  .small-font { font-size: 20px; }

  .keyboard-mask { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: transparent; }
  
  .save-section {
    margin-top: 40px;
    height: 72px;
    border-radius: 26px;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
  }
  .save-btn-txt { font-size: 28px; color: #fff; font-weight: bold; }

  .delete-section {
    height: 72px;
    border-radius: 26px;
    border: 2px solid rgba(255, 69, 58, 0.3);
