  /* Theme Circles */
  .theme-row { flex-direction: row; justify-content: space-around; width: 100%; margin-top: 8px; }
  .theme-circle { width: 50px; height: 50px; border-radius: 25px; border: 4px solid #1C1C1E; justify-content: center; align-items: center; }
