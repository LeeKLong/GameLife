  .modal-btns { flex-direction: row; width: 100%; justify-content: center; }
  .modal-btn {
    flex: 1; height: 64px; justify-content: center; align-items: center;
    border-radius: 16px; margin: 0 6px;
  }
  .cancel { background-color: #2C2C2E; }
  
  .btn-txt { font-size: 24px; font-weight: bold; }
